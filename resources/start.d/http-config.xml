<?xml version="1.0"?>
<!DOCTYPE Configure PUBLIC "-//Jetty//Configure//EN" "https://www.eclipse.org/jetty/configure_12_0.dtd">

<!-- Configure Jetty for URI Compliance - allow legacy characters like pipe '|' used in question IDs -->
<Configure class="org.eclipse.jetty.server.Server" id="Server">

  <Call name="getConnectors">
    <Item>
      <Call name="getConnectionFactories">
        <Item type="org.eclipse.jetty.http.HttpConnectionFactory">
          <Call name="getHttpConfiguration">
            <Set name="uriCompliance">
              <New class="org.eclipse.jetty.http.UriCompliance$Preset">
                <Arg>LEGACY</Arg>
              </New>
            </Set>
          </Call>
        </Item>
      </Call>
    </Item>
  </Call>

</Configure>
